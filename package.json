{
  "name": "ecotrack-carbon-footprint",
  "version": "1.0.0",
  "description": "EcoTrack — a smart personal carbon footprint assistant that helps individuals understand, track, and reduce their emissions through personalized, context-aware insights.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node --test",
    "build": "node ./scripts/build.js",
    "start": "node ./scripts/serve.js",
    "serve": "node ./scripts/serve.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "carbon-footprint",
    "sustainability",
    "climate",
    "co2",
    "assistant"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4"
  }
}
